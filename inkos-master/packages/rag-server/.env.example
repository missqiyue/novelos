# FastAPI RAG Microservice Configuration

# Embedding API (e.g. ModelScope, Ollama)
EMBED_API_TYPE=openai
EMBED_BASE_URL=https://api-inference.modelscope.cn/v1
EMBED_MODEL=Qwen/Qwen3-Embedding-8B
EMBED_API_KEY=your_modelscope_api_key

# Rerank API (e.g. Jina, Ollama)
RERANK_API_TYPE=openai
RERANK_BASE_URL=https://api.jina.ai/v1
RERANK_MODEL=jina-reranker-v3
RERANK_API_KEY=your_jina_api_key

# Time Decay & Recency Config
CONTEXT_RANKER_RECENCY_WEIGHT=0.7
CONTEXT_RANKER_FREQUENCY_WEIGHT=0.3
